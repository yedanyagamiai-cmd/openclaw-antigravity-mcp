{
  "name": "openclaw-antigravity-mcp",
  "version": "2.0.0",
  "type": "module",
  "description": "MCP server for Antigravity Claude Proxy — use Claude Opus 4.6, Sonnet 4.6, and Gemini 3 via any MCP client. TypeScript, tested, zero-config.",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "bin": {
    "openclaw-antigravity-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "antigravity",
    "claude",
    "claude-opus",
    "claude-sonnet",
    "gemini",
    "ai",
    "free",
    "proxy",
    "llm",
    "claude-code",
    "cursor",
    "model-context-protocol",
    "openclaw",
    "typescript"
  ],
  "author": "OpenClaw Intelligence <openclaw-intel@proton.me>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yedanyagamiai-cmd/openclaw-antigravity-mcp"
  },
  "homepage": "https://github.com/yedanyagamiai-cmd/openclaw-antigravity-mcp",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
